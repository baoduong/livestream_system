{
  "name": "livestream-comment-panel",
  "version": "1.0.0",
  "description": "Livestream order operator panel - comment feed & quick confirm",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
